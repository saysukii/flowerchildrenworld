# Flower Children World — environment variables
# Copy to .env for local dev. Set the same values in Railway (Supabase vars are required at build + runtime).

# ── Supabase (client + server) ──────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Injected into the client bundle at build time (must match the values above)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Public website origin — used for intake form links (flowerchildren.world/join, etc.)
VITE_PUBLIC_SITE_ORIGIN=https://flowerchildren.world

# Inside app origin — absolute URLs in emails (logo, team invite links). Usually inside.flowerchildren.world
APP_ORIGIN=https://inside.flowerchildren.world

# Transactional email via Resend (team invites + form confirmations)
# Verify your sending domain at resend.com/domains, then use e.g. Flower Children World <hello@flowerchildren.world>
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Flower Children World <hello@flowerchildren.world>

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Connect — OAuth for donation analytics (Settings → Connect in Stripe Dashboard)
# Platform secret key + Connect client ID. Register redirect URI: {your-app-url}/api/stripe/callback
STRIPE_SECRET_KEY=sk_test_your_platform_secret_key
STRIPE_CLIENT_ID=ca_your_connect_client_id

# Donation widget (Framer microsite → POST /api/donations/checkout)
# CORS origin for the public donation page; also used for Checkout success/cancel URLs
# Must match the exact origin of the Framer page hosting the widget (no trailing slash)
DONATION_WIDGET_ORIGIN=https://flowerchildren.world

# Stripe webhook — register POST {your-app-url}/api/stripe/webhook in Stripe Dashboard
# Enable "Events on Connected accounts" so checkout.session.completed from Connect charges are delivered
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Admin bootstrap (scripts/create-admin.mjs only)
ADMIN_EMAIL=info@flowerchildren.world
ADMIN_PASSWORD=your-admin-password

# Optional — for `npm run db:garden` migration script
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
